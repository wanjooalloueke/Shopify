<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_black | default: '#000000' }}">

    <link rel="canonical" href="{{ canonical_url }}">

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <style>
      :root {
        --jd-black: {{ settings.color_black | default: '#000000' }};
        --jd-gold: {{ settings.color_gold | default: '#D4AF37' }};
        --jd-white: {{ settings.color_white | default: '#FFFFFF' }};
      }
    </style>

    {{ content_for_header }}
    {{ 'theme.js' | asset_url | script_tag }}
  </head>

  <body class="template-{{ template.name | handle }}">
    <a class="skip-link" href="#MainContent">Aller au contenu</a>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Store",
        "name": {{ shop.name | json }},
        "description": {{ shop.description | default: "Boutique de perruques premium à Abidjan, Côte d'Ivoire." | json }},
        "url": {{ shop.url | json }},
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Abidjan",
          "addressCountry": "CI"
        }
      }
    </script>
  </body>
</html>
