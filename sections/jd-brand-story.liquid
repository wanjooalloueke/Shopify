{%- liquid
  if section.settings.image != blank
    assign story_image = section.settings.image | image_url: width: 600
  else
    assign story_image = 'jd-hero.png' | asset_url
  endif
-%}

<section class="section-spacing">
  <div class="page-width brand-story">
    <div class="brand-story__visual">
      <img src="{{ story_image }}" alt="{{ section.settings.image_alt | escape }}" loading="lazy" width="500" height="730">
      <div class="brand-story__panel">
        <strong>{{ section.settings.panel_title }}</strong>
        <span>{{ section.settings.panel_text }}</span>
      </div>
    </div>

    <div class="rich-text">
      <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>

      <ul class="signature-list">
        {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>
            <span>{{ forloop.index }}</span>
            <div>
              <strong>{{ block.settings.title }}</strong>
              <p>{{ block.settings.text }}</p>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Histoire de marque",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texte alternatif",
      "default": "Perruque premium JD Hair"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Accroche",
      "default": "La marque"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Une boutique pensée pour les femmes modernes d'Abidjan"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "JD HAIR BOUTIQUE sélectionne des perruques premium qui apportent confiance, élégance et liberté au quotidien. Chaque modèle met l'accent sur le naturel, le confort et la facilité d'entretien."
    },
    {
      "type": "text",
      "id": "panel_title",
      "label": "Titre panneau",
      "default": "JD HAIR"
    },
    {
      "type": "text",
      "id": "panel_text",
      "label": "Texte panneau",
      "default": "Premium wigs boutique à Abidjan"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point de marque",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Rendu naturel"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte",
          "default": "Des textures et finitions sélectionnées pour un résultat élégant dès la pose."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Histoire de marque",
      "blocks": [
        {
          "type": "point",
          "settings": {
            "title": "Rendu naturel",
            "text": "Textures, volumes et finitions pensés pour sublimer sans effort."
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "Conseil personnalisé",
            "text": "Un accompagnement pour choisir la coupe, la longueur et l'entretien adaptés."
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "Service local",
            "text": "Livraison en Côte d'Ivoire et proximité avec la clientèle d'Abidjan."
          }
        }
      ]
    }
  ]
}
{% endschema %}
