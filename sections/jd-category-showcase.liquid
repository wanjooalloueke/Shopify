<section class="collection-strip section-spacing">
  <div class="page-width">
    <div class="section-header">
      <div>
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.link_label != blank -%}
        <a class="button-secondary" href="{{ section.settings.link_url | default: '/collections/all' }}">{{ section.settings.link_label }}</a>
      {%- endif -%}
    </div>

    <div class="collection-cards">
      {%- for block in section.blocks -%}
        {%- liquid
          assign block_collection = block.settings.collection
          assign card_title = block.settings.title
          assign card_link = block.settings.link
          if block_collection != blank
            assign card_title = block_collection.title
            assign card_link = block_collection.url
          endif
        -%}

        <a class="collection-card" href="{{ card_link | default: '/collections/all' }}" {{ block.shopify_attributes }}>
          <div class="collection-card__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 760 | image_tag: loading: 'lazy', widths: '380, 560, 760', sizes: '(min-width: 990px) 25vw, 50vw', alt: card_title }}
            {%- elsif block_collection.image != blank -%}
              {{ block_collection.image | image_url: width: 760 | image_tag: loading: 'lazy', widths: '380, 560, 760', sizes: '(min-width: 990px) 25vw, 50vw', alt: card_title }}
            {%- elsif block_collection.products.first.featured_media != blank -%}
              {{ block_collection.products.first.featured_media | image_url: width: 760 | image_tag: loading: 'lazy', widths: '380, 560, 760', sizes: '(min-width: 990px) 25vw, 50vw', alt: card_title }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="collection-card__content">
            <h3 class="collection-card__title">{{ card_title }}</h3>
            <p class="collection-card__meta">{{ block.settings.caption }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Catégories JD",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Accroche",
      "default": "Sélection signature"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Trouvez la perruque qui épouse votre style"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Libellé du lien",
      "default": "Tout voir"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Lien"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Catégorie",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre de secours",
          "default": "Lace wigs"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Texte court",
          "default": "Naturel, raffiné, prêt à porter"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Lien de secours"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Catégories JD",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Lace wigs",
            "caption": "Finitions naturelles"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Bob & carrés",
            "caption": "Chic, léger, moderne"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Longues longueurs",
            "caption": "Volume et allure"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Ondulées",
            "caption": "Mouvement naturel"
          }
        }
      ]
    }
  ]
}
{% endschema %}
