<section class="collection-hero">
  <div class="page-width">
    <p class="collection-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="collection-title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection-description">{{ collection.description }}</div>
    {%- endif -%}
  </div>
</section>

<section class="collection-grid-wrap">
  <div class="page-width">
    <div class="collection-toolbar">
      <span>{{ collection.products_count }} produit{% unless collection.products_count == 1 %}s{% endunless %}</span>
      <form method="get">
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        <label class="visually-hidden" for="SortBy">Trier</label>
        <select id="SortBy" name="sort_by" onchange="this.form.submit()">
          {%- for option in collection.sort_options -%}
            <option value="{{ option.value }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name }}</option>
          {%- endfor -%}
        </select>
      </form>
    </div>

    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="product-grid">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- else -%}
          <div class="empty-state">
            <h2>Aucun produit pour le moment</h2>
            <p>Ajoutez vos premières perruques dans Shopify pour remplir cette collection.</p>
          </div>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" role="navigation" aria-label="Pagination">
          {{ paginate | default_pagination }}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Grille collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Accroche",
      "default": "Boutique"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 12,
      "max": 36,
      "step": 4,
      "label": "Produits par page",
      "default": 24
    }
  ]
}
{% endschema %}
