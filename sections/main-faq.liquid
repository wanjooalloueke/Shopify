<section class="page-hero">
  <div class="page-width">
    <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="page-title">{{ section.settings.heading }}</h1>
    <p class="page-subtitle">{{ section.settings.subtitle }}</p>
  </div>
</section>

<section class="faq-wrap">
  <div class="page-width">
    <div class="accordion">
      {%- for block in section.blocks -%}
        <details {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <div class="accordion__content">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ JD",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Accroche",
      "default": "Questions fréquentes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Tout savoir avant de commander"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Livraison, entretien, choix du modèle et service client: les réponses essentielles."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Livrez-vous partout en Côte d'Ivoire ?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Réponse",
          "default": "<p>Oui, la boutique peut organiser la livraison à Abidjan et dans les autres villes selon les modalités confirmées au moment de la commande.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ JD",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "Livrez-vous partout en Côte d'Ivoire ?",
            "answer": "<p>Oui, la livraison est prévue à Abidjan et dans les autres villes selon les modalités de commande.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Comment choisir la bonne perruque ?",
            "answer": "<p>Vous pouvez choisir selon la longueur, la texture, la densité et le rendu souhaité. JD HAIR peut aussi vous conseiller avant l'achat.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Comment entretenir ma perruque ?",
            "answer": "<p>Utilisez des soins doux, démêlez délicatement et évitez les sources de chaleur excessives. Les conseils varient selon la fibre et la texture du modèle.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Puis-je commander via WhatsApp ?",
            "answer": "<p>Oui, vous pouvez utiliser le contact WhatsApp si la boutique l'active dans les paramètres du thème.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
