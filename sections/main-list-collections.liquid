<section class="page-hero">
  <div class="page-width">
    <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="page-title">{{ section.settings.heading }}</h1>
    <p class="page-subtitle">{{ section.settings.subtitle }}</p>
  </div>
</section>

<section class="section-spacing">
  <div class="page-width">
    <div class="list-collections-grid">
      {%- for collection in collections -%}
        {%- unless collection.handle == 'frontpage' -%}
          <a class="collection-card" href="{{ collection.url }}">
            <div class="collection-card__media">
              {%- if collection.image != blank -%}
                {{ collection.image | image_url: width: 760 | image_tag: loading: 'lazy', widths: '380, 560, 760', sizes: '(min-width: 990px) 25vw, 50vw', alt: collection.title }}
              {%- elsif collection.products.first.featured_media != blank -%}
                {{ collection.products.first.featured_media | image_url: width: 760 | image_tag: loading: 'lazy', widths: '380, 560, 760', sizes: '(min-width: 990px) 25vw, 50vw', alt: collection.title }}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="collection-card__content">
              <h2 class="collection-card__title">{{ collection.title }}</h2>
              <p class="collection-card__meta">{{ collection.products_count }} produit{% unless collection.products_count == 1 %}s{% endunless %}</p>
            </div>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Liste des collections",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Accroche",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Explorez la boutique"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Lace wigs, carrés, longueurs, textures lisses ou ondulées: trouvez rapidement votre style."
    }
  ]
}
{% endschema %}
