<section class="page-hero">
  <div class="page-width">
    <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="page-title">{{ section.settings.heading }}</h1>
    <p class="page-subtitle">{{ section.settings.subtitle }}</p>
  </div>
</section>

<section class="page-width payment-layout">
  {%- if cart.item_count > 0 -%}
    <div class="payment-panel">
      <p class="section-eyebrow">{{ section.settings.rule_eyebrow }}</p>
      <h2>{{ section.settings.rule_heading }}</h2>
      <p>{{ section.settings.rule_text }}</p>

      <div class="payment-rule-list">
        <div>
          <strong>{{ section.settings.local_title }}</strong>
          <p>{{ section.settings.local_text }}</p>
        </div>
        <div>
          <strong>{{ section.settings.shipping_title }}</strong>
          <p>{{ section.settings.shipping_text }}</p>
        </div>
        <div>
          <strong>{{ section.settings.confirmation_title }}</strong>
          <p>{{ section.settings.confirmation_text }}</p>
        </div>
      </div>

      <form action="{{ routes.cart_url }}" method="post" class="payment-confirmation-form">
        <input type="hidden" name="attributes[Mode de paiement]" value="Paiement a la livraison">
        <input type="hidden" name="attributes[Exception expedition]" value="Depot complet de l'article requis avant expedition si applicable">

        <label class="payment-acceptance">
          <input type="checkbox" name="attributes[Conditions de paiement acceptees]" value="Oui" required>
          <span>{{ section.settings.acceptance_text }}</span>
        </label>

        <button class="button button-full" type="submit" name="checkout">{{ section.settings.checkout_label }}</button>
        <a class="button-secondary button-full" href="{{ routes.cart_url }}">{{ section.settings.back_label }}</a>
      </form>
    </div>

    <aside class="payment-summary-card">
      <h2>Resume de commande</h2>
      <div class="payment-items">
        {%- for item in cart.items -%}
          <div class="payment-item">
            {%- if item.image -%}
              {{ item.image | image_url: width: 180 | image_tag: loading: 'lazy', widths: '90, 140, 180', alt: item.product.title }}
            {%- endif -%}
            <div>
              <strong>{{ item.product.title }}</strong>
              {%- unless item.product.has_only_default_variant -%}
                <span>{{ item.variant.title }}</span>
              {%- endunless -%}
              <span>Quantite: {{ item.quantity }}</span>
            </div>
            <span>{{ item.final_line_price | money }}</span>
          </div>
        {%- endfor -%}
      </div>

      <div class="payment-total">
        <span>Sous-total</span>
        <strong>{{ cart.total_price | money }}</strong>
      </div>
      <p>Les frais de livraison sont confirmes selon la destination.</p>
    </aside>
  {%- else -%}
    <div class="empty-state">
      <h2>Votre panier est vide.</h2>
      <p>Ajoutez une perruque JD HAIR avant de valider le paiement.</p>
      <a class="button" href="/collections/all">Aller a la boutique</a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Page paiement JD",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Accroche",
      "default": "Validation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Paiement et validation de commande"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Avant de continuer, prenez connaissance des conditions de paiement JD HAIR BOUTIQUE."
    },
    {
      "type": "text",
      "id": "rule_eyebrow",
      "label": "Accroche des regles",
      "default": "Conditions de paiement"
    },
    {
      "type": "text",
      "id": "rule_heading",
      "label": "Titre des regles",
      "default": "Paiement a la livraison, avec exception pour les expeditions"
    },
    {
      "type": "textarea",
      "id": "rule_text",
      "label": "Texte des regles",
      "default": "JD HAIR BOUTIQUE privilegie le paiement a la livraison pour les commandes locales. Pour certaines expeditions, le depot complet du montant de l'article peut etre demande avant l'envoi."
    },
    {
      "type": "text",
      "id": "local_title",
      "label": "Titre paiement local",
      "default": "Commandes locales"
    },
    {
      "type": "textarea",
      "id": "local_text",
      "label": "Texte paiement local",
      "default": "Le paiement se fait uniquement a la livraison, apres confirmation de votre commande et de votre adresse."
    },
    {
      "type": "text",
      "id": "shipping_title",
      "label": "Titre expedition",
      "default": "Expeditions"
    },
    {
      "type": "textarea",
      "id": "shipping_text",
      "label": "Texte expedition",
      "default": "Si la commande doit etre expediee hors de la zone de livraison standard, JD HAIR peut demander le depot complet de l'article avant expedition."
    },
    {
      "type": "text",
      "id": "confirmation_title",
      "label": "Titre confirmation",
      "default": "Confirmation"
    },
    {
      "type": "textarea",
      "id": "confirmation_text",
      "label": "Texte confirmation",
      "default": "Un membre de l'equipe peut vous contacter pour confirmer la disponibilite, la livraison et les modalites exactes."
    },
    {
      "type": "textarea",
      "id": "acceptance_text",
      "label": "Texte d'acceptation",
      "default": "J'ai compris que le paiement se fait a la livraison, sauf expedition necessitant le depot complet de l'article avant envoi."
    },
    {
      "type": "text",
      "id": "checkout_label",
      "label": "Bouton checkout",
      "default": "Continuer la validation"
    },
    {
      "type": "text",
      "id": "back_label",
      "label": "Bouton retour",
      "default": "Retour au panier"
    }
  ]
}
{% endschema %}
